generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  role          UserRole  @default(ADMIN)
  orgId         String?   @map("org_id")
  organization  Organization? @relation(fields: [orgId], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")
  
  providerCredentials ProviderCredential[]
  alerts              Alert[]
  webhooks            Webhook[]
  apiKeys             ApiKey[]
  sessions            Session[]
  
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@map("sessions")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(FREE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  users       User[]
  teams       Team[]
  projects    Project[]
  usageLogs   UsageLog[]
  billing     BillingRecord[]
  
  @@map("organizations")
}

model Team {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now()) @map("created_at")
  
  projects    Project[]
  apiKeys     ApiKey[]
  
  @@map("teams")
}

model Project {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teamId      String?  @map("team_id")
  team        Team?    @relation(fields: [teamId], references: [id])
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  
  usageLogs   UsageLog[]
  
  @@map("projects")
}

model Provider {
  id            String       @id @default(uuid())
  slug          String       @unique
  name          String
  category      ProviderCategory
  logoUrl       String?      @map("logo_url")
  website       String?
  docsUrl       String?      @map("docs_url")
  oauthEnabled  Boolean      @default(false) @map("oauth_enabled")
  oauthScopes   String[]     @map("oauth_scopes")
  regions       String[]
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  
  credentials   ProviderCredential[]
  pricingModels PricingModel[]
  usageLogs     UsageLog[]
  
  @@map("providers")
}

model ProviderCredential {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId      String    @map("provider_id")
  provider        Provider  @relation(fields: [providerId], references: [id])
  
  credentialType  CredType  @map("credential_type")
  encryptedKey    String    @map("encrypted_key")
  keyLastFour     String?   @map("key_last_four")
  scope           String?   // read-only, write, etc.
  region          String?   @default("us-east-1")
  isActive        Boolean   @default(true) @map("is_active")
  lastSyncedAt    DateTime? @map("last_synced_at")
  lastSyncStatus  SyncStatus? @map("last_sync_status")
  syncError       String?   @map("sync_error")
  metadata        Json?     // provider-specific config
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  usageLogs       UsageLog[]
  
  @@map("provider_credentials")
}

model PricingModel {
  id              String    @id @default(uuid())
  providerId      String    @map("provider_id")
  provider        Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  
  modelId         String    @map("model_id") // provider's model identifier
  modelName       String    @map("model_name")
  category        ModelCategory
  
  // Normalized pricing per 1M units
  inputPrice      Decimal   @map("input_price") @db.Decimal(10, 6)
  outputPrice     Decimal   @map("output_price") @db.Decimal(10, 6)
  imagePrice      Decimal?  @map("image_price") @db.Decimal(10, 6) // per image
  audioPrice      Decimal?  @map("audio_price") @db.Decimal(10, 6) // per minute
  contextPrice    Decimal?  @map("context_price") @db.Decimal(10, 6) // per 1M context tokens
  
  region          String    @default("global")
  currency        String    @default("USD")
  billingUnit     String    @default("per_1m_tokens") @map("billing_unit")
  
  // Plan tiers
  planTier        PlanTier  @default(PAY_AS_YOU_GO) @map("plan_tier")
  enterpriseRate  Decimal?  @map("enterprise_rate") @db.Decimal(10, 6)
  volumeDiscount  Json?     @map("volume_discount") // thresholds
  
  effectiveFrom   DateTime  @map("effective_from")
  effectiveTo     DateTime? @map("effective_to")
  isCurrent       Boolean   @default(true) @map("is_current")
  
  sourceUrl       String?   @map("source_url")
  scrapedAt       DateTime  @default(now()) @map("scraped_at")
  
  @@map("pricing_models")
}

model UsageLog {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  org             Organization @relation(fields: [orgId], references: [id])
  
  providerId      String    @map("provider_id")
  provider        Provider  @relation(fields: [providerId], references: [id])
  credentialId    String?   @map("credential_id")
  credential      ProviderCredential? @relation(fields: [credentialId], references: [id])
  
  projectId       String?   @map("project_id")
  project         Project?  @relation(fields: [projectId], references: [id])
  
  modelId         String    @map("model_id")
  modelName       String    @map("model_name")
  
  // Token metrics
  tokensIn        Int       @map("tokens_in")
  tokensOut       Int       @map("tokens_out")
  tokensTotal     Int       @map("tokens_total")
  
  // Cost (normalized to USD)
  costInput       Decimal   @map("cost_input") @db.Decimal(12, 6)
  costOutput      Decimal   @map("cost_output") @db.Decimal(12, 6)
  costTotal       Decimal   @map("cost_total") @db.Decimal(12, 6)
  
  // Performance
  latencyMs       Int       @map("latency_ms")
  statusCode      Int       @map("status_code")
  
  // Metadata
  region          String    @default("us-east-1")
  requestType     String?   @map("request_type") // chat, completion, embedding, image
  endpoint        String?
  timestamp       DateTime
  
  // Raw data (for debugging/auditing)
  rawPayload      Json?     @map("raw_payload")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  @@index([orgId, timestamp])
  @@index([providerId, timestamp])
  @@index([modelId, timestamp])
  @@index([projectId, timestamp])
  @@map("usage_logs")
}

model Recommendation {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  
  category        RecCategory
  severity        RecSeverity
  title           String
  description     String
  
  // Financial impact
  currentMonthlyCost  Decimal @map("current_monthly_cost") @db.Decimal(12, 2)
  recommendedMonthlyCost Decimal @map("recommended_monthly_cost") @db.Decimal(12, 2)
  monthlySavings  Decimal   @map("monthly_savings") @db.Decimal(12, 2)
  savingsPercent  Decimal   @map("savings_percent") @db.Decimal(5, 2)
  annualSavings   Decimal   @map("annual_savings") @db.Decimal(12, 2)
  
  // Action details
  currentPlan     String?   @map("current_plan")
  recommendedPlan String?   @map("recommended_plan")
  currentProvider String?   @map("current_provider")
  recommendedProvider String? @map("recommended_provider")
  currentModel    String?   @map("current_model")
  recommendedModel String?  @map("recommended_model")
  
  // Evidence
  evidence        Json[]    // supporting data points
  confidenceScore Decimal   @map("confidence_score") @db.Decimal(3, 2) // 0.00-1.00
  
  // Status
  status          RecStatus @default(ACTIVE)
  dismissedAt     DateTime? @map("dismissed_at")
  dismissedBy     String?   @map("dismissed_by")
  appliedAt       DateTime? @map("applied_at")
  appliedBy       String?   @map("applied_by")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@map("recommendations")
}

model Alert {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  alertType       AlertType @map("alert_type")
  
  // Thresholds
  thresholdValue  Decimal   @map("threshold_value") @db.Decimal(12, 2)
  thresholdUnit   String    @map("threshold_unit") // USD, percent, tokens
  comparison      String    @default("gt") // gt, lt, gte, lte
  
  // Scope
  providerId      String?   @map("provider_id")
  modelId         String?   @map("model_id")
  projectId       String?   @map("project_id")
  teamId          String?   @map("team_id")
  
  // Notification
  channels        String[]  // email, slack, discord, webhook
  webhookUrl      String?   @map("webhook_url")
  emailRecipients String[]  @map("email_recipients")
  
  isActive        Boolean   @default(true) @map("is_active")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  triggerCount    Int       @default(0) @map("trigger_count")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  alertHistory    AlertHistory[]
  
  @@map("alerts")
}

model AlertHistory {
  id          String   @id @default(uuid())
  alertId     String   @map("alert_id")
  alert       Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  
  triggeredAt DateTime @default(now()) @map("triggered_at")
  value       Decimal  @db.Decimal(12, 2)
  message     String
  sentTo      String[] @map("sent_to")
  status      String   @default("sent") // sent, failed, resolved
  
  @@map("alert_history")
}

model Webhook {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  url         String
  secret      String?  // for signature verification
  events      String[] // usage.spike, cost.anomaly, recommendation.new, etc.
  isActive    Boolean  @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("webhooks")
}

model ApiKey {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId      String?  @map("team_id")
  team        Team?    @relation(fields: [teamId], references: [id])
  
  name        String
  keyHash     String   @map("key_hash")
  keyPrefix   String   @map("key_prefix")
  scopes      String[]
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@map("api_keys")
}

model BillingRecord {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  org         Organization @relation(fields: [orgId], references: [id])
  
  period      String   // YYYY-MM
  providerId  String?  @map("provider_id")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  status      String   @default("projected") // projected, confirmed, invoiced
  breakdown   Json?    // by model, by region, etc.
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("billing_records")
}

model Forecast {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  
  period      String   // YYYY-MM-DD
  periodType  String   @map("period_type") // day, week, month
  
  projectedCost   Decimal @map("projected_cost") @db.Decimal(12, 2)
  lowerBound    Decimal @map("lower_bound") @db.Decimal(12, 2)
  upperBound    Decimal @map("upper_bound") @db.Decimal(12, 2)
  confidence    Decimal @map("confidence") @db.Decimal(3, 2)
  
  // Breakdown
  providerBreakdown Json @map("provider_breakdown")
  modelBreakdown    Json @map("model_breakdown")
  
  generatedAt   DateTime @default(now()) @map("generated_at")
  
  @@map("forecasts")
}

model WasteDetection {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  
  detectionType   String    @map("detection_type") // over_provisioned, duplicate, unused, downgrade
  severity        RecSeverity
  
  // Target
  providerId      String?   @map("provider_id")
  modelId         String?   @map("model_id")
  credentialId    String?   @map("credential_id")
  teamId          String?   @map("team_id")
  
  title           String
  description     String
  evidence        Json[]
  
  estimatedWaste  Decimal   @map("estimated_waste") @db.Decimal(12, 2)
  
  status          String    @default("open") // open, dismissed, resolved
  createdAt       DateTime  @default(now()) @map("created_at")
  resolvedAt      DateTime? @map("resolved_at")
  
  @@map("waste_detections")
}

model SyncJob {
  id            String   @id @default(uuid())
  credentialId  String   @map("credential_id")
  
  status        String   @default("pending") // pending, running, completed, failed
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  
  recordsProcessed  Int   @map("records_processed")
  recordsInserted   Int   @map("records_inserted")
  errorMessage      String? @map("error_message")
  
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@map("sync_jobs")
}

// Enums
enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  VIEWER
}

enum OrgPlan {
  FREE
  STARTUP
  BUSINESS
  ENTERPRISE
}

enum ProviderCategory {
  LLM
  IMAGE
  AUDIO
  EMBEDDING
  MULTIMODAL
}

enum CredType {
  API_KEY
  OAUTH_TOKEN
  AWS_ROLE
  AZURE_SERVICE_PRINCIPAL
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
  NEVER
}

enum ModelCategory {
  CHAT
  COMPLETION
  EMBEDDING
  IMAGE_GENERATION
  IMAGE_EDITING
  AUDIO_TRANSCRIPTION
  AUDIO_GENERATION
  MODERATION
  FINE_TUNING
}

enum PlanTier {
  FREE
  PAY_AS_YOU_GO
  PRO
  ENTERPRISE
  CUSTOM
}

enum RecCategory {
  PLAN_OPTIMIZATION
  MODEL_DOWNGRADE
  PROVIDER_SWITCH
  VOLUME_DISCOUNT
  REGION_OPTIMIZATION
  UNUSED_RESOURCE
  DUPLICATE_USAGE
  CAPACITY_RIGHTSIZING
}

enum RecSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum RecStatus {
  ACTIVE
  DISMISSED
  APPLIED
  EXPIRED
}

enum AlertType {
  BUDGET_THRESHOLD
  ANOMALY_DETECTION
  SPIKE_DETECTION
  FORECAST_EXCEEDED
  NEW_RECOMMENDATION
  UNUSED_RESOURCE
  COST_INCREASE
}
